{
  "name": "webapp",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "start:dev": "npm run dev:relay & npm run dev",
    "deps:upgrade": "bash ../../scripts/upgrade-package-json-deps.sh --target webapp",
    "dev": "vite",
    "relay:compiler": "relay-compiler",
    "dev:relay": "npm run relay:compiler -- --watch",
    "relay": "npm run relay:compiler",
    "analyze": "npm run relay && tsc -b && vite build --mode analyze",
    "build": "npm run relay && tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-router": "^1.168.25",
    "@vanilla-extract/css": "^1.20.1",
    "@vanilla-extract/recipes": "^0.5.7",
    "api-contract": "0.0.1",
    "graphql-ws": "^6.0.8",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "react-relay": "^20.1.1",
    "relay-runtime": "^20.1.1",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@eslint/js": "^10.0.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@types/babel__core": "^7.20.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-relay": "^18.2.1",
    "@types/relay-runtime": "^20.1.1",
    "@vanilla-extract/vite-plugin": "^5.2.2",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-relay": "^20.1.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "graphql": "^16.13.2",
    "relay-compiler": "^20.1.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.10"
  }
}
