{
  "name": "server",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "files": [
    "dist/**/*"
  ],
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "deps:upgrade": "bash ../../scripts/upgrade-package-json-deps.sh server",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "cross-env NODE_ENV=development nest start --watch",
    "start:debug": "cross-env NODE_ENV=development nest start --debug --watch",
    "start:prod": "node dist/main",
    "graphql:schema": "node -r ts-node/register ./src/scripts/generate-schema.ts",
    "graphql:schema:watch": "node --watch --watch-path=src -r ts-node/register ./src/scripts/generate-schema.ts",
    "typeorm": "node -r ts-node/register ./node_modules/typeorm/cli.js",
    "migration:create": "npm run typeorm -- migration:create src/database/migrations/ManualMigration",
    "migration:generate": "npm run typeorm -- migration:generate src/database/migrations/GeneratedMigration -d src/database/typeorm.datasource.ts",
    "migration:show": "npm run typeorm -- migration:show -d src/database/typeorm.datasource.ts",
    "migration:run": "npm run typeorm -- migration:run -d src/database/typeorm.datasource.ts",
    "migration:run:dist": "node ./node_modules/typeorm/cli.js migration:run -d dist/database/typeorm.datasource.js",
    "migration:revert": "npm run typeorm -- migration:revert -d src/database/typeorm.datasource.ts",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@apollo/server": "^5.5.0",
    "@as-integrations/fastify": "^3.1.0",
    "@automapper/classes": "^8.8.1",
    "@automapper/core": "^8.8.1",
    "@automapper/types": "^6.3.1",
    "@nestjs/apollo": "^13.2.5",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/graphql": "^13.2.5",
    "@nestjs/platform-fastify": "^11.1.19",
    "@nestjs/typeorm": "^11.0.1",
    "class-validator": "^0.15.1",
    "graphql": "^16.13.2",
    "graphql-query-complexity": "^1.1.0",
    "graphql-subscriptions": "^3.0.0",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "typeorm": "^0.3.28",
    "@graphql-tools/utils": "~11.0.1",
    "ioredis": "^5.10.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.19",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.30",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/supertest": "^7.2.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.5.0",
    "jest": "^30.3.0",
    "prettier": "^3.8.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.spec.json"
        }
      ]
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
