{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:rush-delivery:schema:dagger:rush-cache-providers",
  "title": "Dagger Rush Cache Providers",
  "type": "object",
  "additionalProperties": false,
  "required": ["cache", "providers"],
  "properties": {
    "cache": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "key_files", "paths"],
      "properties": {
        "version": {
          "type": "string",
          "description": "User-controlled cache schema/version salt.",
          "minLength": 1
        },
        "key_files": {
          "type": "array",
          "description": "Repository-relative files whose contents invalidate the Rush install cache.",
          "items": {
            "$ref": "#/$defs/repoRelativePath"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "paths": {
          "type": "array",
          "description": "Absolute container cache paths owned by Dagger. Paths may be outside the mounted source workspace, or under /workspace/.dagger/runtime so Rush deploy can follow dependency symlinks within the workspace.",
          "items": {
            "$ref": "#/$defs/cachePath"
          },
          "minItems": 1,
          "uniqueItems": true
        }
      }
    },
    "providers": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "github": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "repository_env", "token_env", "username_env"],
          "properties": {
            "kind": {
              "const": "github_container_registry"
            },
            "registry": {
              "type": "string",
              "description": "OCI registry host for GitHub Container Registry.",
              "minLength": 1,
              "default": "ghcr.io"
            },
            "image_namespace": {
              "type": "string",
              "description": "Image path segment used under owner/repo for Rush install cache images.",
              "pattern": "^[a-z0-9][a-z0-9._-]*$",
              "default": "rush-delivery-caches"
            },
            "repository_env": {
              "$ref": "#/$defs/envName",
              "description": "Host env key containing the GitHub owner/repo value."
            },
            "token_env": {
              "$ref": "#/$defs/envName",
              "description": "Host env key containing the registry token."
            },
            "username_env": {
              "$ref": "#/$defs/envName",
              "description": "Host env key containing the registry username."
            }
          }
        }
      }
    }
  },
  "$defs": {
    "cachePath": {
      "type": "string",
      "anyOf": [
        {
          "pattern": "^/(?!workspace(?:/|$))(?!.*(?:^|/)\\.\\.(?:/|$)).+"
        },
        {
          "pattern": "^/workspace/\\.dagger/runtime/(?!.*(?:^|/)\\.\\.(?:/|$)).+"
        }
      ]
    },
    "envName": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9_]*$"
    },
    "repoRelativePath": {
      "type": "string",
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+"
    }
  }
}
