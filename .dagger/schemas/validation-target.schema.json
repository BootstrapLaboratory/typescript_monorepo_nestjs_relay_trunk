{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:rush-delivery:schema:dagger:validation-target",
  "title": "Dagger Validation Target",
  "type": "object",
  "additionalProperties": false,
  "required": ["name"],
  "properties": {
    "name": {
      "$ref": "#/$defs/identifier",
      "description": "Validation target name. Must match the metadata filename and Rush packageName."
    },
    "services": {
      "type": "object",
      "description": "Backing services available to validation steps.",
      "propertyNames": {
        "$ref": "#/$defs/identifier"
      },
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["image"],
        "properties": {
          "image": {
            "type": "string",
            "minLength": 1
          },
          "env": {
            "$ref": "#/$defs/stringMap"
          },
          "ports": {
            "$ref": "#/$defs/ports"
          }
        }
      }
    },
    "steps": {
      "type": "array",
      "description": "Ordered validation steps.",
      "items": {
        "oneOf": [
          {
            "$ref": "#/$defs/commandStep"
          },
          {
            "$ref": "#/$defs/serviceStep"
          }
        ]
      }
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "stringMap": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "ports": {
      "type": "array",
      "items": {
        "type": "integer",
        "minimum": 1,
        "maximum": 65535
      },
      "uniqueItems": true
    },
    "commandStep": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command", "name"],
      "properties": {
        "name": {
          "$ref": "#/$defs/identifier"
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "args": {
          "$ref": "#/$defs/stringArray"
        },
        "env": {
          "$ref": "#/$defs/stringMap"
        }
      }
    },
    "serviceStep": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "service"],
      "properties": {
        "name": {
          "$ref": "#/$defs/identifier"
        },
        "service": {
          "type": "object",
          "additionalProperties": false,
          "required": ["command"],
          "properties": {
            "command": {
              "type": "string",
              "minLength": 1
            },
            "args": {
              "$ref": "#/$defs/stringArray"
            },
            "env": {
              "$ref": "#/$defs/stringMap"
            },
            "ports": {
              "$ref": "#/$defs/ports"
            }
          }
        }
      }
    }
  }
}
