{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:rush-delivery:schema:dagger:toolchain-image-providers",
  "title": "Dagger Toolchain Image Providers",
  "type": "object",
  "additionalProperties": false,
  "required": ["providers"],
  "properties": {
    "providers": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "github": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "repository_env", "token_env", "username_env"],
          "properties": {
            "kind": {
              "const": "github_container_registry"
            },
            "registry": {
              "type": "string",
              "description": "OCI registry host for GitHub Container Registry.",
              "minLength": 1,
              "default": "ghcr.io"
            },
            "image_namespace": {
              "type": "string",
              "description": "Image path segment used under owner/repo for framework toolchain images.",
              "pattern": "^[a-z0-9][a-z0-9._-]*$",
              "default": "rush-delivery-toolchains"
            },
            "repository_env": {
              "$ref": "#/$defs/envName",
              "description": "Host env key containing the GitHub owner/repo value."
            },
            "token_env": {
              "$ref": "#/$defs/envName",
              "description": "Host env key containing the registry token."
            },
            "username_env": {
              "$ref": "#/$defs/envName",
              "description": "Host env key containing the registry username."
            }
          }
        }
      }
    }
  },
  "$defs": {
    "envName": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9_]*$"
    }
  }
}
