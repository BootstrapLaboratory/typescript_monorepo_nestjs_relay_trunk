{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:rush-delivery:schema:dagger:deploy-target",
  "title": "Dagger Deploy Target",
  "type": "object",
  "additionalProperties": false,
  "required": ["deploy_script", "name", "runtime"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Target name. Must match the metadata filename and Rush packageName.",
      "minLength": 1
    },
    "deploy_script": {
      "type": "string",
      "description": "Repository-relative deploy script path.",
      "minLength": 1
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["image"],
      "properties": {
        "image": {
          "type": "string",
          "description": "Container image used to execute the deploy script.",
          "minLength": 1
        },
        "install": {
          "type": "array",
          "description": "Shell commands used to prepare the target executor container.",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "pass_env": {
          "$ref": "#/$defs/envNameArray",
          "description": "1:1 host env to executor env allowlist."
        },
        "env": {
          "$ref": "#/$defs/envMap",
          "description": "Static executor environment variables."
        },
        "dry_run_defaults": {
          "$ref": "#/$defs/envMap",
          "description": "Default values used for pass_env keys during dry runs."
        },
        "required_host_env": {
          "$ref": "#/$defs/envNameArray",
          "description": "Host env keys required for live runs."
        },
        "file_mounts": {
          "type": "array",
          "description": "Files mounted into the runtime container from the runtime files bundle or, for compatibility, host-file paths sourced from required host env paths.",
          "items": {
            "oneOf": [
              {
                "type": "object",
                "additionalProperties": false,
                "required": ["source"],
                "properties": {
                  "source": {
                    "$ref": "#/$defs/repoRelativePath",
                    "description": "Path inside the runtime files bundle. Defaults to the same path under /runtime-files."
                  },
                  "target": {
                    "type": "string",
                    "description": "Container path where the file is mounted.",
                    "minLength": 1
                  }
                }
              },
              {
                "type": "object",
                "additionalProperties": false,
                "required": ["source_var", "target"],
                "properties": {
                  "source_var": {
                    "$ref": "#/$defs/envName",
                    "description": "Host env key containing the source file path."
                  },
                  "target": {
                    "type": "string",
                    "description": "Container path where the file is mounted.",
                    "minLength": 1
                  }
                }
              }
            ]
          }
        },
        "workspace": {
          "type": "object",
          "description": "Runtime workspace mounted into the deploy executor. Omit mode to mount only listed dirs/files; use mode=full for the whole repo.",
          "additionalProperties": false,
          "properties": {
            "mode": {
              "type": "string",
              "const": "full",
              "description": "Mount the full prepared repository at /workspace."
            },
            "dirs": {
              "$ref": "#/$defs/repoRelativePathArray",
              "description": "Repository-relative directories mounted under /workspace."
            },
            "files": {
              "$ref": "#/$defs/repoRelativePathArray",
              "description": "Repository-relative files mounted under /workspace."
            }
          }
        }
      }
    }
  },
  "$defs": {
    "envName": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9_]*$"
    },
    "envNameArray": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/envName"
      },
      "uniqueItems": true
    },
    "envMap": {
      "type": "object",
      "propertyNames": {
        "$ref": "#/$defs/envName"
      },
      "additionalProperties": {
        "type": "string"
      }
    },
    "repoRelativePath": {
      "type": "string",
      "minLength": 1,
      "not": {
        "anyOf": [
          {
            "pattern": "^/"
          },
          {
            "pattern": "^[A-Za-z]:[\\\\/]"
          },
          {
            "pattern": "(^|/)\\.\\.(/|$)"
          }
        ]
      }
    },
    "repoRelativePathArray": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/repoRelativePath"
      },
      "uniqueItems": true
    }
  }
}
