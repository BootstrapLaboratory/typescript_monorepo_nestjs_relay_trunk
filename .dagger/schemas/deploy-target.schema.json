{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:rush-delivery:schema:dagger:deploy-target",
  "title": "Dagger Deploy Target",
  "type": "object",
  "additionalProperties": false,
  "required": ["deploy_script", "name", "runtime"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Target name. Must match the metadata filename and Rush packageName.",
      "minLength": 1
    },
    "deploy_script": {
      "type": "string",
      "description": "Repository-relative deploy script path.",
      "minLength": 1
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["image"],
      "properties": {
        "image": {
          "type": "string",
          "description": "Container image used to execute the deploy script.",
          "minLength": 1
        },
        "install": {
          "type": "array",
          "description": "Shell commands used to prepare the target executor container.",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "pass_env": {
          "$ref": "#/$defs/envNameArray",
          "description": "1:1 host env to executor env allowlist."
        },
        "env": {
          "$ref": "#/$defs/envMap",
          "description": "Static executor environment variables."
        },
        "dry_run_defaults": {
          "$ref": "#/$defs/envMap",
          "description": "Default values used for pass_env keys during dry runs."
        },
        "required_host_env": {
          "$ref": "#/$defs/envNameArray",
          "description": "Host env keys required for live runs."
        },
        "file_mounts": {
          "type": "array",
          "description": "Host-file mounts sourced from required host env paths.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["source_var", "target"],
            "properties": {
              "source_var": {
                "$ref": "#/$defs/envName",
                "description": "Host env key containing the source file path."
              },
              "target": {
                "type": "string",
                "description": "Container path where the file is mounted.",
                "minLength": 1
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "envName": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9_]*$"
    },
    "envNameArray": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/envName"
      },
      "uniqueItems": true
    },
    "envMap": {
      "type": "object",
      "propertyNames": {
        "$ref": "#/$defs/envName"
      },
      "additionalProperties": {
        "type": "string"
      }
    }
  }
}
