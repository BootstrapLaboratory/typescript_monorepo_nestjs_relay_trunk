{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:rush-delivery:schema:dagger:package-target",
  "title": "Dagger Package Target",
  "type": "object",
  "additionalProperties": false,
  "required": ["artifact", "name"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Target name. Must match the metadata filename and Rush packageName.",
      "minLength": 1
    },
    "artifact": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "path"],
          "properties": {
            "kind": {
              "const": "directory"
            },
            "path": {
              "type": "string",
              "description": "Repository-relative built artifact directory.",
              "minLength": 1
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "output", "project", "scenario"],
          "properties": {
            "kind": {
              "const": "rush_deploy_archive"
            },
            "project": {
              "type": "string",
              "description": "Rush project passed to rush deploy.",
              "minLength": 1
            },
            "scenario": {
              "type": "string",
              "description": "Rush deploy scenario.",
              "minLength": 1
            },
            "output": {
              "type": "string",
              "description": "Repository-relative rush deploy output directory.",
              "minLength": 1
            }
          }
        }
      ]
    }
  }
}
