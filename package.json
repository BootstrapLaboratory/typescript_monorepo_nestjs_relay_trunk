{
  "name": "typescript_nestjs_relay_trunk_monorepo",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "bash scripts/run-nx-dev.sh",
    "dev:rush": "node common/scripts/install-run-rush.js dev",
    "deps:upgrade": "bash scripts/upgrade-package-json-deps.sh --target all",
    "deps:upgrade:root": "bash scripts/upgrade-package-json-deps.sh --target root",
    "deps:upgrade:webapp": "bash scripts/upgrade-package-json-deps.sh --target webapp",
    "deps:upgrade:server": "bash scripts/upgrade-package-json-deps.sh --target server",
    "webapp:analyze": "npm --prefix apps/webapp run analyze",
    "webapp:build:pages": "bash deploy/cloudflare-pages/scripts/build-webapp.sh",
    "server:image:build:local": "docker buildx build --pull --load -f apps/server/Dockerfile -t local/server-cloudrun:dev .",
    "rush": "node common/scripts/install-run-rush.js",
    "rush:install": "node common/scripts/install-run-rush.js install",
    "rush:update": "node common/scripts/install-run-rush.js update",
    "rush:build": "node common/scripts/install-run-rush.js build",
    "rush:version": "node common/scripts/install-run-rush.js version",
    "rush:publish": "node common/scripts/install-run-rush.js publish"
  }
}
