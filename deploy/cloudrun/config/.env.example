# Copy this file to deploy/cloudrun/.env and fill in the real values.

# Google Cloud project and GitHub repository identity
PROJECT_ID=""
PROJECT_NAME=""
GITHUB_REPOSITORY=""
BILLING_ACCOUNT_ID=""

# Fixed deployment defaults for this migration
CLOUD_RUN_REGION="europe-west4"
ARTIFACT_REGISTRY_REPOSITORY="cloud-run-backend"
CLOUD_RUN_SERVICE="api"

# Workload Identity Federation and service account naming
WIF_POOL_ID="github-actions"
WIF_PROVIDER_ID="github"
DEPLOYER_SERVICE_ACCOUNT_ID="github-actions-deployer"
RUNTIME_SERVICE_ACCOUNT_ID="cloud-run-runtime"

# First-rollout frontend/backend wiring
CLOUD_RUN_CORS_ORIGIN="http://localhost:5173"

# Fill these after creating Neon and Redis
DATABASE_URL=""
DATABASE_URL_DIRECT=""
REDIS_URL=""
