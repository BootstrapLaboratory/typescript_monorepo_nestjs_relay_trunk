# Copy this file to deploy/cloudrun/config/.env and fill in the real values.

# Google Cloud project and GitHub repository identity
PROJECT_ID=""
PROJECT_NAME=""
GITHUB_REPOSITORY=""
BILLING_ACCOUNT_ID=""

# Fixed deployment defaults for this migration
CLOUD_RUN_REGION="europe-west4"
ARTIFACT_REGISTRY_REPOSITORY="cloud-run-backend"
CLOUD_RUN_SERVICE="api"

# Workload Identity Federation and service account naming
WIF_POOL_ID="github-actions"
WIF_PROVIDER_ID="github"
DEPLOYER_SERVICE_ACCOUNT_ID="github-actions-deployer"
RUNTIME_SERVICE_ACCOUNT_ID="cloud-run-runtime"

# First-rollout frontend/backend wiring
CLOUD_RUN_CORS_ORIGIN="http://localhost:5173"

# Optional Cloud Monitoring alerting helpers
MONITORING_NOTIFICATION_CHANNELS=""
MONITORING_EMAIL_ADDRESS=""
MONITORING_UPTIME_DISPLAY_NAME=""
MONITORING_UPTIME_PATH="/health"

# Fill these after creating Neon and Redis
# DATABASE_URL should be the pooled runtime connection string.
# DATABASE_URL_DIRECT should stay the higher-privilege direct connection string
# used for migrations and one-time administrative tasks.
DATABASE_URL=""
DATABASE_URL_DIRECT=""
REDIS_URL=""

# CloudFlare Pages access
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_API_TOKEN=""
CLOUDFLARE_PAGES_PROJECT_NAME=""
CLOUDFLARE_PAGES_PRODUCTION_BRANCH="main"

# Optional explicit frontend API target overrides.
# If left empty, the Cloudflare Pages GitHub variable helper derives them from
# the currently deployed Cloud Run service URL.
WEBAPP_VITE_GRAPHQL_HTTP=""
WEBAPP_VITE_GRAPHQL_WS=""
