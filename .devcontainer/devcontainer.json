{
  "name": "bootstraplaboratory.template.typescript_monorepo_nestjs_relay_trunk",
  "dockerComposeFile": [
    "docker-compose.localdb.yml",
    "docker-compose.devcontainer.yml"
  ],
  "service": "devcontainer",
  "remoteUser": "root",
  "runServices": ["postgres", "pgadmin"],
  // "features": {
  //   "ghcr.io/devcontainers/features/node:1": {
  //     "version": "24.13.0"
  //   }
  // },
  "customizations": {
    "vscode": {
      "settings": {
        "editor.formatOnSave": true
      },
      "extensions": [
        "eamodio.gitlens",
        "pflannery.vscode-versionlens",
        "ms-azuretools.vscode-containers",
        "jebbs.plantuml",
        "openai.chatgpt",
        "trunk.io",
        "meta.relay",
        "dbaeumer.vscode-eslint"
      ]
    }
  },
  "forwardPorts": [],
  "postStartCommand": "",
  "containerUser": "root",
  // "runArgs": ["--userns=keep-id"],
  "workspaceFolder": "/workspace",
  "mounts": ["source=home,target=/root,type=volume"],
  "postCreateCommand": "bash -lc 'bash /workspace/.devcontainer/postCreate.sh'"
}
